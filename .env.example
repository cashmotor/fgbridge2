# Feishu App Credentials
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_USER_ID=your_open_id_here

# App Settings
POLL_INTERVAL=20
DB_PATH=fgb_state.db
LOG_LEVEL=INFO
SHOW_FULL_HISTORY=false
ATTACHMENT_DIR=data/attachments
# 文档导出类型 (pdf, docx, csv, etc.)，若为空则直接提取 Markdown 文本
FEISHU_DOC_TYPE=pdf
FEISHU_SHEET_TYPE=csv

# Gemini CLI Settings
GEMINI_BIN_PATH=gemini
# Gemini 运行的工作目录 (可选)
GEMINI_CWD=
# 指定启动时复制到工作目录的 gemini.md 文件路径 (可选)
GEMINI_MD_PATH=
# 是否启用沙盒模式 (--sandbox)
GEMINI_USE_SANDBOX=false
# 是否自动确认操作 (--yolo)
GEMINI_USE_YOLO=false
# http_proxy=http://127.0.0.1:1089
# https_proxy=http://127.0.0.1:1089
