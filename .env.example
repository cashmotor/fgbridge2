# Feishu App Credentials
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_USER_ID=your_user_id(OpenID)
FEISHU_BOT_NAME=FGAssistant

# App Settings
DB_PATH=data/fgbridge.db
SESSION_DIR=data/sessions
ATTACHMENT_DIR=data/attachments
LOG_LEVEL=INFO

# Business Strategy
ASSISTANT_TTL=3600
EXPERT_TTL=600
LONG_RESPONSE_THRESHOLD=150
ASSISTANT_ROLE=ProjectManager
REACTION_GET=Get
REACTION_DONE=Done

# Gemini CLI Settings
GEMINI_BIN_PATH=gemini
GEMINI_CWD=
GEMINI_MD_TEMPLATE_PATH=/你的/路径/xxx.md
GEMINI_USE_SANDBOX=true
GEMINI_USE_YOLO=false
# Proxy Settings (Optional)
# HTTP_PROXY=http://127.0.0.1:1089
# HTTPS_PROXY=http://127.0.0.1:1089
